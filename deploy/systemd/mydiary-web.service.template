[Unit]
Description=MyDiary Web (frontend preview)
After=network.target mydiary-api.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory={{APP_DIR}}
Environment=NODE_ENV=production
Environment=HOME={{APP_DIR}}
Environment=PATH=/usr/local/bin:/usr/bin:/bin:{{APP_DIR}}/node_modules/.bin
ExecStart=/usr/bin/env npm run preview -- --host 0.0.0.0 --port 4173
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
